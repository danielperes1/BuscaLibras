<%- include('../partials/head', { titulo: 'Login' }) %>

<body class="page-login">

  <div class="container">

    <!-- Logo do sistema -->
    <img src="/img/logo.png" alt="Busca Libras" class="logo">

    <h1>Login</h1>

    <!-- Formulário de autenticação do usuário -->
    <form action="/usuarios/login" method="POST">

      <div class="input-group">
        <label>Email</label>
        <div class="input-box">
          <i class="fa-solid fa-envelope"></i>
          <input type="email" name="email" placeholder="Digite seu email" required>
        </div>
      </div>

      <div class="input-group">
        <label>Senha</label>
        <div class="input-box">
          <i class="fa-solid fa-lock"></i>
          <input type="password" name="senha" placeholder="Digite sua senha" required>
        </div>
      </div>

      <div class="forgot-password">
        <a href="/redefinicaoSenha">Esqueceu a senha?</a>
      </div>

      <button class="btn-login">Entrar</button>

      <div class="register">
        Não tem conta?
        <a href="/escolha">Cadastre-se</a>
      </div>

    </form>

  </div>

</body>
</html>
