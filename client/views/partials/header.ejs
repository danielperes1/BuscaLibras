<header class="site-header">
  <div class="header-inner">

    <!-- Logo do sistema e link para a página inicial -->
    <a href="/" class="header-logo">
      <img src="/img/logo.png" alt="Busca Libras" />
    </a>

    <!-- Menu de navegação que muda conforme o perfil do usuário -->
    <nav class="header-nav">
      <% if (usuario && usuario.perfil === 'administrador') { %>
        <a href="/usuarios" class="nav-link <%= typeof paginaAtual !== 'undefined' && paginaAtual === 'usuarios' ? 'active' : '' %>">Home</a>
        <a href="/profissionais" class="nav-link">Profissionais</a>
        <a href="/solicitantes" class="nav-link">Solicitantes</a>
      <% } else if (usuario && usuario.perfil === 'profissional') { %>
        <a href="/dashboard/inicio" class="nav-link">Home</a>
        <a href="/meu-perfil" class="nav-link">Meu Perfil</a>
      <% } else if (usuario && usuario.perfil === 'solicitante') { %>
        <a href="/profissionais/vitrine" class="nav-link">Home</a>
        <a href="/meu-perfil" class="nav-link">Meu Perfil</a>
      <% } %>
    </nav>

    <!-- Informações do usuário logado e ação de logout -->
    <div class="header-user">
      <% if (usuario) { %>
        <span class="header-greeting">Olá, <%= usuario.nome %></span>
        <span class="header-badge header-badge--<%= usuario.perfil %>">
          <%= usuario.perfil === 'administrador' ? 'ADM' : usuario.perfil === 'profissional' ? 'PRO' : 'SOL' %>
        </span>
        <a href="/usuarios/logout" class="header-logout" title="Sair">
          <i class="fa-solid fa-right-from-bracket"></i>
        </a>
      <% } %>
    </div>

  </div>
</header>
